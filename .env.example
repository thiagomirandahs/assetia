# Copie este arquivo para .env e preencha com suas credenciais.
# O arquivo .env esta no .gitignore — NUNCA sera commitado.

# === LLM provider — Anthropic Claude OU Google Gemini (free) ===
# Auto-detecta. Forca um com: LLM_PROVIDER=anthropic | gemini
LLM_PROVIDER=

# Anthropic Claude (pago — gere em https://console.anthropic.com/settings/keys)
ANTHROPIC_API_KEY=
ANTHROPIC_MODEL=claude-sonnet-4-6

# Google Gemini (free tier 1500 req/dia — gere em https://aistudio.google.com/apikey)
GEMINI_API_KEY=
GEMINI_MODEL=gemini-2.5-flash

# Groq (free tier muito generoso — gere em https://console.groq.com/keys)
GROQ_API_KEY=
GROQ_MODEL=llama-3.3-70b-versatile

# === JWT ===
# Gere com: python -c "import secrets; print(secrets.token_urlsafe(32))"
JWT_SECRET=troque-isso-em-producao-por-um-segredo-real-de-32-bytes
JWT_ALGORITHM=HS256
JWT_EXPIRE_MINUTES=1440

# === Banco de dados ===
# Para SQLite local (dev):
DATABASE_URL=sqlite:///./assetia.sqlite
# Para PostgreSQL (prod):
# DATABASE_URL=postgresql+psycopg2://user:pass@localhost:5432/assetia

# === Scanner ===
DEFAULT_NETWORK=192.168.1.0/24
SCAN_TIMEOUT_SECONDS=3
MAX_PARALLEL_PINGS=64

# === Anonimato (privacidade / OSINT autorizado) ===
# Roteia os scans por um proxy SOCKS5. Para Tor: instale o Tor e use a porta 9050.
# Deixe vazio para conexao direta. Ex: SOCKS_PROXY=socks5://127.0.0.1:9050
SOCKS_PROXY=

# === Servidor ===
HOST=0.0.0.0
PORT=8000
CORS_ORIGINS=http://localhost:5173,http://localhost:3000

# === Alertas — canais opcionais (deixe vazio para desabilitar) ===

# E-mail (SMTP)
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
ALERT_EMAIL_TO=

# Telegram (crie um bot via @BotFather e pegue o chat_id)
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=
